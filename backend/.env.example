# =====================================================================
# Variables de entorno del modulo de requerimientos
# Copie este archivo como .env y ajuste los valores.
# =====================================================================

# ---------------------------------------------------------------------
# Servidor
# ---------------------------------------------------------------------
PORT=4000
# development | production | test
NODE_ENV=development

# ---------------------------------------------------------------------
# Conexion a PostgreSQL (DESARROLLO LOCAL)
# Se usan estas variables cuando NO se define DATABASE_URL.
# ---------------------------------------------------------------------
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=dexter
PGPASSWORD=dexter_dev_2026
PGDATABASE=dexter_requerimientos

# Base de datos para pruebas automatizadas (jest)
PGDATABASE_TEST=dexter_requerimientos_test

# ---------------------------------------------------------------------
# Conexion a PostgreSQL (PRODUCCION / RAILWAY)
# Si DATABASE_URL esta presente, tiene prioridad sobre las variables PG*.
# En Railway, referencie la del plugin de Postgres: ${{Postgres.DATABASE_URL}}
# ---------------------------------------------------------------------
# DATABASE_URL=postgresql://usuario:clave@host:5432/basededatos
#
# SSL: por defecto se activa cuando hay DATABASE_URL (lo exige Railway).
# Para desactivarlo (por ejemplo en local) use PGSSL=disable.
# PGSSL=require

# ---------------------------------------------------------------------
# Seguridad / autenticacion (RNF-09)
# En produccion DEFINA una clave larga y aleatoria.
# ---------------------------------------------------------------------
JWT_SECRET=cambie-esta-clave-en-produccion-dexter-2026
JWT_EXPIRES_IN=8h

# ---------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------
# Origen permitido para CORS. En el deploy de un solo servicio (Express sirve
# el SPA) el frontend es del mismo origen, por lo que CORS no es necesario.
# Mantenga el valor local para desarrollo con Vite (puerto 5173).
CORS_ORIGIN=http://localhost:5173

# Servir el frontend compilado (frontend/dist) desde Express.
# true|false. Por defecto: activo salvo en pruebas. En Railway dejelo en true.
# SERVE_CLIENT=true

# Ruta alternativa del build del frontend (normalmente no hace falta cambiarla).
# CLIENT_DIST_PATH=/ruta/a/frontend/dist
